{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/esec/assets/:path*",
      "destination": "/assets/:path*"
    },
    { "source": "/esec/", "destination": "/index.html" },
    { "source": "/esec", "destination": "/index.html" }
  ]
}